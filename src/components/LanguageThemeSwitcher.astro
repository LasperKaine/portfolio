---
---

<div class="switcher-container">
  <form class="language-switcher" id="langForm" aria-label="Language switcher">
    <fieldset>
      <legend class="sr-only">Select language</legend>
      <label>
        <input type="radio" name="language" value="en" aria-label="English" />
        EN
      </label>

      <label>
        <input type="radio" name="language" value="fi" aria-label="Finnish" />
        FI
      </label>

      <label>
        <input type="radio" name="language" value="sv" aria-label="Swedish" />
        SV
      </label>
    </fieldset>
    <button type="submit" class="sr-only">Apply language</button>
  </form>

  <button 
    class="theme-btn" 
    id="themeBtn" 
    type="button"
    aria-label="Toggle dark/light theme"
    aria-pressed="false"
  >
    <svg class="sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <circle cx="12" cy="12" r="5"></circle>
      <line x1="12" y1="1" x2="12" y2="3"></line>
      <line x1="12" y1="21" x2="12" y2="23"></line>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
      <line x1="1" y1="12" x2="3" y2="12"></line>
      <line x1="21" y1="12" x2="23" y2="12"></line>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
    </svg>

    <svg class="moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
  </button>
</div>

<script is:inline>
  const themeBtn = document.getElementById('themeBtn');

  const savedTheme = localStorage.getItem('theme') || 'dark';

  document.documentElement.setAttribute('data-theme', savedTheme);

  function updateThemeDisplay(theme) {
    const sun = document.querySelector('.sun-icon');
    const moon = document.querySelector('.moon-icon');

    if (!sun || !moon) return;

    sun.style.display = theme === 'dark' ? 'none' : 'block';
    moon.style.display = theme === 'dark' ? 'block' : 'none';
    
    if (themeBtn) {
      themeBtn.setAttribute('aria-pressed', theme === 'light' ? 'true' : 'false');
    }
  }

  updateThemeDisplay(savedTheme);

  themeBtn?.addEventListener('click', () => {
    const current =
      document.documentElement.getAttribute('data-theme') || 'dark';

    const newTheme = current === 'dark' ? 'light' : 'dark';

    localStorage.setItem('theme', newTheme);

    document.documentElement.setAttribute('data-theme', newTheme);

    updateThemeDisplay(newTheme);
  });

  const langForm = document.getElementById('langForm');

  const savedLang = localStorage.getItem('language') || 'en';

  if (langForm) {
    const currentRadio = langForm.querySelector(
      `input[value="${savedLang}"]`
    );

    if (currentRadio) {
      currentRadio.checked = true;
    }

    langForm.addEventListener('change', (e) => {
      const target = e.target;

      if (!target) return;

      if (target.name === 'language') {
        localStorage.setItem('language', target.value);

        // Dispatch event to trigger translations
        window.dispatchEvent(new Event('languageChanged'));

        // Reload page to apply all translations
        setTimeout(() => {
          location.reload();
        }, 100);
      }
    });

    // Prevent actual form submission
    langForm.addEventListener('submit', (e) => {
      e.preventDefault();
    });
  }
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .switcher-container {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .language-switcher {
    display: flex;
    gap: 0.5rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.25rem;
    margin: 0;
  }

  .language-switcher fieldset {
    display: flex;
    gap: 0.5rem;
    border: none;
    margin: 0;
    padding: 0;
  }

  .language-switcher label {
    background: transparent;
    border: none;
    padding: 0.5rem 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    border-radius: 0.375rem;
    color: var(--text-secondary);
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .language-switcher input[type='radio'] {
    display: none;
    background-color: #974eec;
  }

  .language-switcher label:has(input:checked) {
    background: var(--accent);
    color: white;
  }

  .language-switcher label:hover {
    color: var(--text-primary);
  }

  .theme-btn {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--text-primary);
    padding: 0;
    transition: all 0.2s ease;
    position: relative;
  }

  .theme-btn:hover {
    opacity: 0.8;
  }

  .theme-btn svg {
    width: 1.25rem;
    height: 1.25rem;
    position: absolute;
  }

  @media (max-width: 768px) {
    .language-switcher {
      gap: 0.25rem;
    }

    .language-switcher fieldset {
      gap: 0.25rem;
    }

    .language-switcher label {
      padding: 0.4rem 0.6rem;
      font-size: 0.75rem;
    }

    .theme-btn {
      width: 2rem;
      height: 2rem;
    }

    .theme-btn svg {
      width: 1rem;
      height: 1rem;
    }
  }
</style>