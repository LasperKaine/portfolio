---
import BaseLayout from "./layouts/BaseLayout.astro";
---

<BaseLayout title="About — LasperKaine">
  <section class="about-page">
    <div class="about-container">
      <h1 class="glitch">ABOUT ME</h1>
      <p><strong>Location:</strong> Helsinki, Finland</p>
      <section class="about-section">
        <h2>Bio</h2>
        <p>
          Junior Full-Stack Developer currently studying Bachelor of Engineering
          (ICT) at Metropolia University of Applied Sciences. Experienced in
          building web applications with React, Node.js, and WordPress. I've
          worked in professional settings on real client projects, and I'm
          passionate about clean code and modern development practices.
        </p>
        <p>
          Looking for my first junior developer role where I can contribute
          meaningfully and grow alongside experienced engineers. Based in
          Helsinki, Finland.
        </p>
      </section>

      <section class="about-section">
        <h2>Tech Stack</h2>
        <div class="tech-grid">
          <div class="tech-card">
            <h3>Frontend</h3>
            <p>
              HTML5, CSS3, SCSS, JavaScript, React, Vue, Tailwind, TypeScript,
              Astro
            </p>
          </div>
          <div class="tech-card">
            <h3>Backend</h3>
            <p>Node.js, Express.js, PHP, REST APIs</p>
          </div>
          <div class="tech-card">
            <h3>Databases</h3>
            <p>MongoDB, MariaDB, Firebase, MySQL</p>
          </div>
          <div class="tech-card">
            <h3>Tools</h3>
            <p>
              Git, GitHub, BitBucket, VS Code, Figma, Postman, Linux, NPM, Jira,
              Confluence, Jira, Trello, HeidiSQL
            </p>
          </div>
        </div>
      </section>

      <section class="about-section">
        <h2>What I'm Looking For</h2>
        <ul class="looking-for-list">
          <li>Junior Full-Stack or Frontend Developer role</li>
          <li>Remote or hybrid opportunity</li>
          <li>Team that values learning and code quality</li>
          <li>Chance to work on real products with modern tech stack</li>
        </ul>
      </section>

      <section class="about-section">
        <h2>Experience</h2>
        <div class="experience-item">
          <h3>Frontend / WordPress Developer</h3>
          <p class="exp-company">Alfons Digital Oy (Jan 2024 – May 2024)</p>
          <p class="exp-desc">
            Developed and maintained WordPress websites using React, PHP, and
            Tailwind. Built responsive UI components, worked with Git/NPM
            workflows, and collaborated on multiple client projects.
          </p>
        </div>
        <div class="experience-item">
          <h3>IT Support Assistant</h3>
          <p class="exp-company">Helsingin kaupunki (Aug – Oct 2022)</p>
          <p class="exp-desc">
            Provided IT support, troubleshooting devices, and created user
            documentation. Worked with Windows, iOS, and Android platforms.
          </p>
        </div>
      </section>
      <section class="about-section">
        <h2>Education</h2>
        <div class="experience-item">
          <h3>Bachelor of Engineering (ICT)</h3>
          <p class="exp-company">
            Metropolia University of Applied Sciences (2025 – Present)
          </p>
          <p class="exp-desc">
            Majoring in Software Production. Focused on software engineering,
            backend systems, and modern application development.
          </p>
        </div>
        <div class="experience-item">
          <h3>Vocational Qualification in ICT</h3>
          <p class="exp-company">
            Business College Helsinki (Aug 2021 – May 2024)
          </p>
          <p class="exp-desc">
            Specialized in web development with practical experience in
            JavaScript, Node.js, React, and team-based software projects.
          </p>
        </div>
      </section>
      <section class="about-section cta-section">
        <h2>Let's Connect</h2>
        <p>Have an opportunity or want to chat? Here's where to find me:</p>
        <div class="connect-buttons">
          <a
            href="https://github.com/LasperKaine"
            target="_blank"
            rel="noopener"
            class="button-purple">GitHub</a
          >
          <a
            href="https://www.linkedin.com/in/kasper-laine-a4a131231/"
            target="_blank"
            rel="noopener"
            class="button-purple">LinkedIn</a
          >
          <a
            href="/resume.pdf"
            target="_blank"
            rel="noopener"
            class="button-ghost">Resume</a
          >
          <a href="/contact" class="button-ghost">Email Me</a>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
