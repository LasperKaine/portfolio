---
import BaseLayout from './layouts/BaseLayout.astro'
---

<BaseLayout title="About — LasperKaine">
  <section class="about-page">
    <div class="about-container">
      <h1 class="glitch">ABOUT ME</h1>

      <section class="about-section">
        <h2>Bio</h2>
        <p>
          Junior developer passionate about building fast, clean web applications. Experienced with modern JavaScript, React, and backend tooling. 
          I've worked in an internship setting (Vue/Firebase), built multiple full-stack projects, and I'm always learning new tools and best practices.
        </p>
        <p>
          I love solving real problems through code, collaborating with teams, and shipping features that users actually need. 
          Looking for my first junior dev role where I can contribute meaningfully and grow alongside experienced engineers.
        </p>
      </section>

      <section class="about-section">
        <h2>Tech Stack</h2>
        <div class="tech-grid">
          <div class="tech-card">
            <h3>Frontend</h3>
            <p>React, Vue, HTML/CSS, Astro, Responsive Design</p>
          </div>
          <div class="tech-card">
            <h3>Backend</h3>
            <p>Node.js, Express, REST APIs, Firebase</p>
          </div>
          <div class="tech-card">
            <h3>Databases</h3>
            <p>MongoDB, Firebase, SQL</p>
          </div>
          <div class="tech-card">
            <h3>Tools</h3>
            <p>Git, GitHub, VS Code, Figma, Postman</p>
          </div>
        </div>
      </section>

      <section class="about-section">
        <h2>What I'm Looking For</h2>
        <ul class="looking-for-list">
          <li>Junior Frontend or Full-Stack Developer role</li>
          <li>Remote or hybrid opportunity preferred</li>
          <li>Team that values code quality & learning</li>
          <li>Chance to work on real products & features</li>
        </ul>
      </section>

      <section class="about-section">
        <h2>Experience</h2>
        <div class="experience-item">
          <h3>Software Engineering Intern</h3>
          <p class="exp-company">Tech Company (Confidential)</p>
          <p class="exp-desc">
            Collaborated on Vue.js and Firebase projects. Participated in sprint planning, code reviews, and QA cycles. 
            Built UI components and integrated backend APIs.
          </p>
        </div>
      </section>

      <section class="about-section cta-section">
        <h2>Let's Connect</h2>
        <p>Have an opportunity or want to chat? Here's where to find me:</p>
        <div class="connect-buttons">
          <a href="https://github.com/LasperKaine" target="_blank" rel="noopener" class="button-purple">GitHub</a>
          <a href="https://linkedin.com/in/LasperKaine" target="_blank" rel="noopener" class="button-purple">LinkedIn</a>
          <a href="/resume.pdf" target="_blank" rel="noopener" class="button-ghost">Resume</a>
          <a href="/contact" class="button-ghost">Email Me</a>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>