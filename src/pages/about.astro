---
import BaseLayout from "./layouts/BaseLayout.astro";
---

<BaseLayout 
  title="About Kasper Laine — Full-Stack Developer"
  description="Learn about Kasper Laine, a full-stack developer from Helsinki with expertise in React, WordPress, PHP, and modern web technologies. View skills, education, and professional experience."
>
  <section class="about-page">
    <div class="about-container">
      <h1 class="glitch" data-i18n="aboutTitle"></h1>

      <section class="about-section">
        <h2 data-i18n="whoIAm"></h2>
        <p data-i18n="whoIAmDesc"></p>
        <p data-i18n="passionate"></p>
        <p>
          <strong data-i18n="location"></strong>: <span data-i18n="helsinki"></span><br />
          <strong data-i18n="email"></strong>:
          <a href="mailto:kasperlaine05@gmail.com">kasperlaine05@gmail.com</a>
        </p>
      </section>

      <section class="about-section">
        <h2 data-i18n="skillset"></h2>
        <ul>
          <li><strong data-i18n="frontendDevelopment"></strong>: <span data-i18n="frontendTechs"></span></li>
          <li><strong data-i18n="backendCMS"></strong>: <span data-i18n="backendTechs"></span></li>
          <li><strong data-i18n="programming"></strong>: <span data-i18n="programmingTechs"></span></li>
          <li><strong data-i18n="tools"></strong>: <span data-i18n="toolsTechs"></span></li>
          <li><strong data-i18n="itSupport"></strong>: <span data-i18n="itSupportTechs"></span></li>
          <li><strong data-i18n="creativeTools"></strong>: <span data-i18n="creativeToolsTechs"></span></li>
          <li><strong data-i18n="projectWork"></strong>: <span data-i18n="projectWorkTechs"></span></li>
          <li><strong data-i18n="languagesSkill"></strong>: <span data-i18n="languagesSkillTechs"></span></li>
        </ul>
      </section>

      <section class="about-section">
        <h2 data-i18n="education"></h2>
        <div class="experience-item">
          <h3 data-i18n="bachelorEngineering"></h3>
          <p class="exp-company" data-i18n="metropolia"></p>
        </div>
        <div class="experience-item">
          <h3 data-i18n="vocationalQualification"></h3>
          <p class="exp-company" data-i18n="businessCollege"></p>
        </div>
      </section>

      <section class="about-section">
        <h2 data-i18n="professionalExperience"></h2>
        <div class="experience-item">
          <h3 data-i18n="fullStackDeveloper"></h3>
          <p class="exp-company" data-i18n="alfonDigital"></p>
          <p class="exp-desc" data-i18n="alfonDesc"></p>
        </div>
        <div class="experience-item">
          <h3 data-i18n="itSupportRole"></h3>
          <p class="exp-company" data-i18n="helsinkiCity"></p>
          <p class="exp-desc" data-i18n="itSupportDesc"></p>
        </div>
      </section>

      <section class="about-section cta-section">
        <h2 data-i18n="contact"></h2>
        <div class="connect-buttons">
          <a
            href="https://github.com/LasperKaine"
            target="_blank"
            rel="noopener"
            class="button-purple"
            data-i18n="github"
            aria-label="Visit GitHub profile (opens in new window)"></a>
          <a
            href="https://linkedin.com/in/kasper-laine-4a131231"
            target="_blank"
            rel="noopener"
            class="button-purple"
            data-i18n="linkedin"
            aria-label="Visit LinkedIn profile (opens in new window)"></a>
          <a
            href="/resume.pdf"
            target="_blank"
            rel="noopener"
            class="button-ghost"
            data-i18n="resume"
            aria-label="Download resume (opens in new window)"></a>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>