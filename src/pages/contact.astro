---
import BaseLayout from './layouts/BaseLayout.astro'
---

<BaseLayout title="Contact — LasperKaine">
  <section class="contact-page">
    <div class="contact-container">
      <h1 class="glitch">GET IN TOUCH</h1>
      <p class="contact-subtitle">
        Have an opportunity, feedback, or just want to connect? Reach out!
      </p>

      <div class="contact-methods">
        <div class="method-card">
          <h2>Email</h2>
          <p>The fastest way to reach me.</p>
          <a href="mailto:kasperlaine05@gmail.com" class="button-purple">Send Email</a>
        </div>

        <div class="method-card">
          <h2>LinkedIn</h2>
          <p>Let's connect on the professional network.</p>
          <a href="https://linkedin.com/in/LasperKaine" target="_blank" rel="noopener" class="button-purple">Visit Profile</a>
        </div>

        <div class="method-card">
          <h2>GitHub</h2>
          <p>Check out my code & open-source work.</p>
          <a href="https://github.com/LasperKaine" target="_blank" rel="noopener" class="button-purple">View GitHub</a>
        </div>
      </div>

      <section class="quick-response">
        <h2>Quick Response Time</h2>
        <p>
          I aim to respond to all inquiries within <strong>24–48 hours</strong>. 
          If you don't hear back, feel free to ping me on LinkedIn.
        </p>
      </section>
    </div>
  </section>
</BaseLayout>