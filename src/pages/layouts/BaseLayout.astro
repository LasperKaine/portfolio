---
import Navbar from "../navbar.astro";
import Footer from "../footer.astro";

const base = import.meta.env.BASE_URL;

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Kasper Laine — Full-Stack Developer Portfolio",
  description = "Full-Stack Developer Portfolio. Experienced web developer specializing in React, WordPress, PHP, and modern web technologies. Based in Helsinki.",
} = Astro.props;
