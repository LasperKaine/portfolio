---
import LanguageThemeSwitcher from '../components/LanguageThemeSwitcher.astro';
import MobileMenu from '../components/MobileMenu.astro';

const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

const isActive = (path: string) =>
  currentPath === path || currentPath.startsWith(path + '/');
---

<nav class="navbar">
  <div class="nav-container">

    <a href={base} class="nav-logo">
      <span class="logo-text">KL</span>
    </a>

    <ul class="nav-links">
      <li><a href={base} class={isActive('/portfolio/') || isActive('/') ? 'active' : ''} data-i18n="home">Home</a></li>
      <li><a href={`${base}projects`} class={isActive('/projects') || isActive('/portfolio/projects') ? 'active' : ''} data-i18n="projects">Projects</a></li>
      <li><a href={`${base}about`} class={isActive('/about') || isActive('/portfolio/about') ? 'active' : ''} data-i18n="about">About</a></li>
      <li><a href={`${base}contact`} class={isActive('/contact') || isActive('/portfolio/contact') ? 'active' : ''} data-i18n="contact">Contact</a></li>
    </ul>

    <div class="nav-socials">
      <a href="https://github.com/LasperKaine" target="_blank" rel="noopener" data-i18n="github">GitHub</a>
      <a href="https://www.linkedin.com/in/kasper-laine-a4a131231/" target="_blank" rel="noopener" data-i18n="linkedin">LinkedIn</a>
      <a href={`${base}resume.pdf`} target="_blank" rel="noopener" class="resume-link" data-i18n="resume">Resume</a>
    </div>

    <div class="nav-controls">
      <LanguageThemeSwitcher />
    </div>

    <MobileMenu currentPath={currentPath} />
  </div>
</nav>

<style>
  .navbar {
    background: var(--bg-primary);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 999;
    box-shadow: 0 2px 12px #a770ef11;
  }

  .nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
    gap: 2rem;
  }

  .nav-logo {
    font-size: 1.5rem;
    font-weight: bold;
    text-decoration: none;
    color: var(--text-primary);
    text-shadow: 0 0 10px #9D50FF;
    min-width: fit-content;
  }

  .logo-text {
    color: var(--accent);
    font-family: 'VT323', monospace;
    letter-spacing: 0.1em;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
    margin: 0;
    padding: 0;
    flex: 1;
  }

  .nav-links a {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.3s, text-shadow 0.3s;
    border-bottom: 2px solid transparent;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--accent);
    text-shadow: 0 0 8px #9D50FF;
    border-bottom-color: var(--accent);
  }

  .nav-socials {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-socials a {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s, text-shadow 0.3s;
  }

  .nav-socials a:hover {
    color: var(--accent);
    text-shadow: 0 0 8px #9D50FF;
  }

  .resume-link {
    padding: 6px 12px;
    border: 1px solid #9D50FF66;
    border-radius: 5px;
    background: transparent;
  }

  .resume-link:hover {
    background: #9D50FF11;
    border-color: #cf71fc;
  }

  .nav-controls {
    display: flex;
    align-items: center;
  }

  @media (max-width: 768px) {
    .nav-container {
      gap: 1rem;
      padding: 1rem;
    }

    .nav-links {
      display: none;
    }

    .nav-socials {
      display: none;
    }

    .nav-controls {
      display: flex;
    }
  }
</style>