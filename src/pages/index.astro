---
import BaseLayout from "./layouts/BaseLayout.astro";
---

<BaseLayout title="Kasper Laine — Web Developer">
  <section class="hero">
    <div class="hero-content">
      <h1 class="glitch">Kasper Laine</h1>
      <h2 class="hero-subtitle" data-i18n="webDeveloper"></h2>
      <p class="hero-desc" data-i18n="heroDesc"></p>
      <div class="hero-ctas">
        <a href="/projects" class="button-purple" data-i18n="viewProjects"></a>
        <a
          href="/resume.pdf"
          target="_blank"
          rel="noopener"
          class="button-ghost"
          data-i18n="resume"></a>
        <a
          href="https://www.linkedin.com/in/kasper-laine-a4a131231/"
          target="_blank"
          rel="noopener"
          class="button-ghost"
          data-i18n="linkedin"></a>
        <a
          href="https://github.com/LasperKaine"
          target="_blank"
          rel="noopener"
          class="button-ghost"
          data-i18n="github"></a>
      </div>
    </div>
  </section>

  <section class="quick-facts">
    <div class="facts-container">
      <h2 class="section-title" data-i18n="quickFacts"></h2>
      <div class="facts-grid">
        <div class="fact">
          <svg
            class="fact-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
            <line x1="2" y1="17" x2="22" y2="17"></line>
            <line x1="6" y1="21" x2="18" y2="21"></line>
          </svg>
          <span class="fact-main" data-i18n="webDeveloper"></span>
          <span class="fact-sub" data-i18n="helsinki"></span>
        </div>
        <div class="fact">
          <svg
            class="fact-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
            <path
              d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"
            ></path>
          </svg>
          <span class="fact-main" data-i18n="bengStudent"></span>
          <span class="fact-sub" data-i18n="softwareProduction"></span>
        </div>
        <div class="fact">
          <svg
            class="fact-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 1 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
            ></path>
          </svg>
          <span class="fact-main" data-i18n="itWeb"></span>
          <span class="fact-sub" data-i18n="background"></span>
        </div>
        <div class="fact">
          <svg
            class="fact-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="2" y1="12" x2="22" y2="12"></line>
            <path
              d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
            ></path>
          </svg>
          <span class="fact-main" data-i18n="languages"></span>
          <span class="fact-sub" data-i18n="languagesLabel"></span>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="cta-box">
      <h2 data-i18n="letsWork"></h2>
      <p data-i18n="collaboration"></p>
      <a href="/contact" class="button-purple" data-i18n="contactMe"></a>
    </div>
  </section>
</BaseLayout>