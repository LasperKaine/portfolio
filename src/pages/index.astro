---
import BaseLayout from "./layouts/BaseLayout.astro";
---

<BaseLayout title="LasperKaine — Junior Developer">
  <section class="hero">
    <div class="hero-content">
      <h1 class="glitch" data-text="LASPER KAINE">Kasper Laine</h1>
      <h2 class="hero-subtitle">Full‑Stack Junior Developer</h2>
      <p class="hero-desc">
        I build fast, clean web applications. Experienced with React, Node.js,
        and modern tooling. Currently studying at Metropolia.
        <br />Open to junior developer opportunities.
      </p>

      <div class="hero-ctas">
        <a href="/projects" class="button-purple">View Projects</a>
        <a
          href="/resume.pdf"
          target="_blank"
          rel="noopener"
          class="button-ghost">Download Resume</a
        >
        <a
          href="https://www.linkedin.com/in/kasper-laine-a4a131231/"
          target="_blank"
          rel="noopener"
          class="button-ghost">LinkedIn</a
        >
      </div>
    </div>
  </section>

  <section class="quick-facts">
    <div class="facts-container">
      <h2 class="section-title">Quick Facts</h2>
      <div class="facts-grid">
        <div class="fact">
          <p class="fact-number">2</p>
          <p class="fact-label">Years in Web Dev</p>
        </div>
        <div class="fact">
          <p class="fact-number">5+</p>
          <p class="fact-label">Languages & Frameworks</p>
        </div>
        <div class="fact">
          <p class="fact-number">React</p>
          <p class="fact-label">Node.js / Express</p>
        </div>
        <div class="fact">
          <p class="fact-number">✓</p>
          <p class="fact-label">Currently @ Metropolia</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="cta-box">
      <h2>Ready to chat?</h2>
      <p>I'm open to opportunities, collaborations, or just a conversation.</p>
      <a href="/contact" class="button-purple">Get in Touch</a>
    </div>
  </section>
</BaseLayout>
