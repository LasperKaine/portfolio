{
  "name": "density-disk",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:a11y": "npm run build && pa11y-ci --config .pa11yci.json",
    "test:seo": "npm run build && lighthouse https://lasperkaine.github.io --output=json --output-path=./lighthouse-report.json",
    "test:all": "npm run test && npm run test:a11y"
  },
  "dependencies": {
    "astro": "^6.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@vitest/ui": "^1.0.0",
    "jsdom": "^29.1.1",
    "lighthouse": "^11.0.0",
    "pa11y-ci": "^3.1.0",
    "vitest": "^1.0.0"
  }
}
